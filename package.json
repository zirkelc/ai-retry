{
  "name": "ai-retry",
  "version": "1.11.0",
  "description": "Retry and fallback mechanisms for AI SDK",
  "keywords": [
    "ai",
    "ai-sdk",
    "fallback",
    "retry"
  ],
  "license": "MIT",
  "author": "Chris Cook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zirkelc/ai-retry.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./embedding-model": "./dist/embedding-model/index.mjs",
    "./embedding-model/conditions": "./dist/embedding-model/conditions/index.mjs",
    "./image-model": "./dist/image-model/index.mjs",
    "./image-model/conditions": "./dist/image-model/conditions/index.mjs",
    "./language-model": "./dist/language-model/index.mjs",
    "./language-model/conditions": "./dist/language-model/conditions/index.mjs",
    "./retryables": "./dist/retryables/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "build": "tsdown",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --fix",
    "lint:ci": "oxlint",
    "format": "oxfmt --write",
    "format:ci": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "3.0.23",
    "@ai-sdk/azure": "3.0.19",
    "@ai-sdk/gateway": "3.0.23",
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/groq": "3.0.15",
    "@ai-sdk/openai": "3.0.19",
    "@ai-sdk/provider": "3.0.5",
    "@ai-sdk/provider-utils": "4.0.9",
    "@ai-sdk/test-server": "1.0.3",
    "@arethetypeswrong/cli": "^0.18.2",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/node": "^25.0.10",
    "ai": "6.0.50",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "pkg-pr-new": "^0.0.62",
    "publint": "^0.3.17",
    "tsdown": "^0.20.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "@ai-sdk/provider-utils": "^4.0.0",
    "@opentelemetry/api": "^1.9.0",
    "ai": "6.x",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "pnpm lint",
      "pnpm format"
    ],
    "*.{json,jsonc}": [
      "pnpm format"
    ]
  },
  "packageManager": "pnpm@10.0.0"
}
